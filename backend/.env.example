# Copy this file to backend/.env and fill in real values.
# .env is gitignored; this .env.example is committed as documentation.
# Loaded automatically by spring-dotenv when the backend starts.

# JWT signing secret (must be at least 32 bytes for HS256)
JWT_SECRET=

# Google OAuth2 "Web application" client (Google Cloud console > Credentials).
# The redirect URI must also be registered there and match the Angular callback route.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4200/auth/google/callback

# Mail — referenced by a future email feature; no mail starter is wired yet, so
# these are currently inert. Use a Gmail App Password (not your account password).
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_AUTH=true
SPRING_MAIL_STARTTLS=true
